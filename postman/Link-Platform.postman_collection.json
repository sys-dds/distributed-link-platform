{
  "info": {
    "_postman_id": "cc1cbf00-f925-46ee-8eac-084dcf3f28f0",
    "name": "Link Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Manual verification requests for the Link Platform foundation, PostgreSQL-backed create-link flow, and redirect-by-slug flow."
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/actuator/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "actuator",
            "health"
          ]
        },
        "description": "Infrastructure health check exposed by Spring Boot Actuator."
      },
      "response": []
    },
    {
      "name": "Liveness",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/actuator/health/liveness",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "actuator",
            "health",
            "liveness"
          ]
        },
        "description": "Process liveness probe exposed by Spring Boot Actuator."
      },
      "response": []
    },
    {
      "name": "Readiness",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/actuator/health/readiness",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "actuator",
            "health",
            "readiness"
          ]
        },
        "description": "Readiness probe exposed by Spring Boot Actuator for current runtime dependencies."
      },
      "response": []
    },
    {
      "name": "Metrics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/actuator/metrics",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "actuator",
            "metrics"
          ]
        },
        "description": "Base Actuator metrics surface listing the available meter names."
      },
      "response": []
    },
    {
      "name": "System Ping",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/system/ping",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "system",
            "ping"
          ]
        },
        "description": "Application-level ping endpoint for Link Platform."
      },
      "response": []
    },
    {
      "name": "Create Link",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"slug\": \"{{createLinkSlug}}\",\n  \"originalUrl\": \"{{createLinkOriginalUrl}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/links",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "links"
          ]
        },
        "description": "Creates a short link in the current application instance and persists it to PostgreSQL."
      },
      "response": []
    },
    {
      "name": "Redirect Link",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/{{createLinkSlug}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "{{createLinkSlug}}"
          ]
        },
        "description": "Resolves a previously created slug from PostgreSQL-backed storage and returns a temporary redirect to the stored original URL."
      },
      "response": []
    }
  ]
}
